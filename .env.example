NODE_ENV=production
COMPOSE_PROJECT_NAME=poly-rewards
PORT=8798
WEB_DIST_DIR=/app/dist/apps/web

# Internal Caddy listener. Keep this as :80 when another server-level proxy
# terminates the public domain and forwards to host port HTTP_PORT.
SITE_DOMAIN=:80
HTTP_PORT=8098

# The rewards runtime is monitor-only by default. Live posting is intentionally
# not wired into the main loop until whitelist accounting is proven.
EXECUTION_MODE=monitor
DASHBOARD_INTERNAL_API_KEY=
APP_VERSION=0.1.0
GIT_SHA=local
BUILD_TIME=local

POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_DEPOSIT_WALLET=
OWNER_PRIVATE_KEY=

BOT_TICK_MS=10000
RUNTIME_STATE_PATH=data/runtime-state.json
RUNTIME_MAX_RECORDS=1000

# Rewards scanner and dry-run quote planner.
REWARDS_ENABLED=true
REWARDS_SCANNER_LIMIT=80
REWARDS_CANDIDATE_LIMIT=12
REWARDS_QUOTE_SIZE=5
REWARDS_QUOTE_OFFSET=0.015
REWARDS_MIN_DAILY_REWARD=1
REWARDS_MIN_SECONDS_TO_CLOSE=86400
REWARDS_GLOBAL_MAX_NOTIONAL=100
REWARDS_MARKET_MAX_NOTIONAL=10
REWARDS_MAX_OPEN_MARKETS=10
REWARDS_MAX_MIDPOINT_DRIFT=0.015
REWARDS_MAX_ORDER_AGE_SECONDS=60
REWARDS_MAX_ORDERBOOK_AGE_SECONDS=5

# Keep live expansion explicit. IDs can be market IDs or condition IDs depending
# on the reward API payload surfaced in the dashboard.
REWARDS_LIVE_WHITELIST_ONLY=true
REWARDS_WHITELIST_MARKET_IDS=

# Conservative first-pass toxicity filters.
REWARDS_BLOCKED_CATEGORIES=crypto,geopolitics
REWARDS_BLOCKED_KEYWORDS=5m,15m,live,in-play,missile,strike,war,attack,breaking
