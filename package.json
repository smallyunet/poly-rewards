{
  "name": "poly-rewards",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:api": "tsx apps/api/src/main.ts",
    "dev:web": "vite --config apps/web/vite.config.ts --host 0.0.0.0",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "docker:build:prod": "sh -c 'SHA=$(git rev-parse --short HEAD); if ! git diff --quiet || ! git diff --cached --quiet; then SHA=$SHA-dirty; fi; APP_VERSION=$npm_package_version GIT_SHA=$SHA BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) docker compose -f docker-compose.prod.yml build'",
    "start:api": "node dist/apps/api/src/main.js",
    "test": "node --import tsx --test \"apps/api/src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p apps/web/tsconfig.json"
  },
  "dependencies": {
    "@ethersproject/wallet": "^5.8.0",
    "@polymarket/clob-client-v2": "^1.0.3-canary.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.0",
    "ws": "^8.21.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
